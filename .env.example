APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite is the documented default (CI + prod both run on SQLite). Point
# DB_DATABASE at an absolute path to the file, e.g. database/database.sqlite.
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
# Local dev uses 'sync' (no worker needed). Production sets 'database' (see
# fly.toml) and runs `php artisan queue:work` so imports/mail run off-request.
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail. Local dev: 'log' writes messages to laravel.log — nothing to run,
# nothing sent. Production sends through SMTP2GO over plain SMTP: set
# MAIL_MAILER=smtp + the MAIL_HOST/PORT/ENCRYPTION/USERNAME/PASSWORD below as
# Fly secrets, with MAIL_FROM_ADDRESS on the SMTP2GO-verified sender domain.
# See docs/deploy.md → SMTP2GO setup. (Port 25 is blocked on Fly; use 587.)
MAIL_MAILER=log
MAIL_HOST=mail.smtp2go.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Scheduled-job failure notifications (emailOutputOnFailure). Falls back to
# MAIL_FROM_ADDRESS when unset.
CRON_FAILURE_EMAIL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- App-specific ------------------------------------------------------------

# Blade admin at /admin (moderation, imports, geocoding). The gate FAILS
# CLOSED: with these unset every /admin request returns 503 — set both or
# the panel is simply unreachable (this is the "why do I get 503 on /admin
# in a fresh checkout" answer).
ADMIN_USER=
ADMIN_PASS=

# Where the API redirects browsers (root URL, OAuth callback landing,
# email verification landing). Default matches the React dev server.
FRONTEND_URL=http://localhost:5174

# Google Sign-In (Socialite). Create a Web OAuth client in Google Cloud
# Console with redirect URI <APP_URL>/auth/google/callback. Unset = the
# "Continue with Google" flow errors; email/password auth still works.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Production error tracking (Sentry). Leave blank to disable — the SDK no-ops
# without a DSN, so dev and any key-less environment stay silent. In prod set
# this as a Fly secret. Get the DSN from sentry.io → Project → Settings → SDK Setup.
SENTRY_LARAVEL_DSN=
# Optional performance tracing: fraction of requests to trace (0.0–1.0). Leave
# unset to capture errors only (no performance data, no extra quota usage).
SENTRY_TRACES_SAMPLE_RATE=
